# ============================================================
# IQRA TOGO — Variables d'environnement (template)
# Copier ce fichier en .env.local pour le développement local.
# Sur Vercel : Project > Settings > Environment Variables
# ============================================================

# ------------------------------------------------------------
# Base de données PostgreSQL — Supabase
# Récupérer depuis : Supabase > Project Settings > Database
# ------------------------------------------------------------

# Connexion POOLÉE via pgBouncer — utilisée par l'application (port 6543)
# Format : postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connexion DIRECTE — utilisée par Prisma pour les migrations (port 5432)
# Format : postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ------------------------------------------------------------
# Supabase Storage — upload de fichiers (images membres, etc.)
# Récupérer depuis : Supabase > Project Settings > API
# ------------------------------------------------------------
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"   # Clé privée — ne jamais exposer côté client

# ------------------------------------------------------------
# NextAuth.js v5
# Générer un secret : openssl rand -base64 32
# ------------------------------------------------------------
AUTH_SECRET="[MIN-32-CHARS-SECRET]"
AUTH_URL="https://iqra-togo.com"
NEXTAUTH_URL="https://iqra-togo.com"

# ------------------------------------------------------------
# Email transactionnel — Resend (resend.com)
# Récupérer depuis : Resend > API Keys
# Domaine à vérifier dans : Resend > Domains
# ------------------------------------------------------------
RESEND_API_KEY="re_[YOUR-RESEND-API-KEY]"
EMAIL_FROM="IQRA TOGO <noreply@iqra-togo.com>"
EMAIL_ADMIN="contact@iqra-togo.com"

# ------------------------------------------------------------
# PayDunya API — paiements en ligne
# Récupérer depuis : dashboard.paydunya.com
# ------------------------------------------------------------
PAYDUNYA_MASTER_KEY="[PAYDUNYA-MASTER-KEY]"
PAYDUNYA_PRIVATE_KEY="[PAYDUNYA-PRIVATE-KEY]"
PAYDUNYA_TOKEN="[PAYDUNYA-TOKEN]"
PAYDUNYA_MODE="test"   # "test" | "live"
PAYDUNYA_WEBHOOK_SECRET="[PAYDUNYA-WEBHOOK-SECRET]"

# ------------------------------------------------------------
# App — variables publiques (exposées au navigateur)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://iqra-togo.com"
NEXT_PUBLIC_APP_NAME="IQRA TOGO"

# ------------------------------------------------------------
# Google Search Console (optionnel)
# Récupérer depuis : Search Console > Paramètres > Vérification du site
# ------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="[TOKEN]"
